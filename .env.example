# ══════════════════════════════════════════════════════════════
# FishClaw 环境配置模板
# 复制此文件为 .env 并填写真实值，不要将 .env 提交到版本控制
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# 爬虫（xianyu_tools）用 LLM 配置
# 用于 crawl4ai 辅助增强：页面结构分析、动态选择器识别
# ──────────────────────────────────────────────────────────────
CRAWLER_LLM_PROVIDER=openai/qwen-plus
CRAWLER_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CRAWLER_LLM_API_KEY=your-dashscope-api-key-here

# ──────────────────────────────────────────────────────────────
# 闲鱼页面 URL 配置
# ──────────────────────────────────────────────────────────────
XIANYU_HOME_URL=https://www.goofish.com
# ──────────────────────────────────────────────────────────────
# 智能体（Agent）用 LLM 配置
# 用于 Agno 智能体推理，与爬虫 LLM 独立配置
# ──────────────────────────────────────────────────────────────
AGENT_LLM_MODEL=qwen-max
AGENT_LLM_API_KEY=your-dashscope-api-key-here
AGENT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AGENT_LLM_TEMPERATURE=0.5
